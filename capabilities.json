{
  "dataRoles": [
    {
      "displayName": "Numeric Field",
      "name": "measure",
      "kind": "Measure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "measure": { "max": 1 } }
      ],
      "single": {
        "role": "measure"
      }
    }
  ],
  "objects": {
    "sliderSettings": {
      "displayName": "Slider",
      "properties": {
        "trackColor":        { "displayName": "Track colour",        "type": { "fill": { "solid": { "color": true } } } },
        "fillColor":         { "displayName": "Fill colour",         "type": { "fill": { "solid": { "color": true } } } },
        "handleColor":       { "displayName": "Handle colour",       "type": { "fill": { "solid": { "color": true } } } },
        "handleBorderColor": { "displayName": "Handle border colour","type": { "fill": { "solid": { "color": true } } } },
        "trackHeight":       { "displayName": "Track height",        "type": { "numeric": true } },
        "handleSize":        { "displayName": "Handle size",         "type": { "numeric": true } },
        "handleShape":       { "displayName": "Handle shape",        "type": { "enumeration": [
          { "value": "circle", "displayName": "Circle" },
          { "value": "square", "displayName": "Square" }
        ] } },
        "fillTransparency":  { "displayName": "Fill transparency",   "type": { "numeric": true } },
        "trackTransparency": { "displayName": "Track transparency",  "type": { "numeric": true } },
        "showBorder":        { "displayName": "Show handle border",  "type": { "bool": true } },
        "borderWidth":       { "displayName": "Handle border width", "type": { "numeric": true } }
      }
    },
    "labels": {
      "displayName": "Labels",
      "properties": {
        "show":             { "displayName": "Show",           "type": { "bool": true } },
        "showMinMax":       { "displayName": "Show data range","type": { "bool": true } },
        "color":            { "displayName": "Color",          "type": { "fill": { "solid": { "color": true } } } },
        "fontSize":         { "displayName": "Text size",      "type": { "numeric": true } },
        "fontFamily":       { "displayName": "Font",           "type": { "formatting": { "fontFamily": true } } },
        "bold":             { "displayName": "Bold",           "type": { "bool": true } },
        "italic":           { "displayName": "Italic",         "type": { "bool": true } },
        "underline":        { "displayName": "Underline",      "type": { "bool": true } },
        "displayUnits":     { "displayName": "Display units",  "type": { "numeric": true } },
        "decimalPlaces":    { "displayName": "Decimal places", "type": { "numeric": true } },
        "prefix":           { "displayName": "Prefix",         "type": { "text": true } },
        "suffix":           { "displayName": "Suffix",         "type": { "text": true } }
      }
    },
    "stepSettings": {
      "displayName": "Step",
      "properties": {
        "autoStep": { "displayName": "Auto step", "type": { "bool": true } },
        "stepValue": { "displayName": "Step value", "type": { "numeric": true } }
      }
    },
    "chartPadding": {
      "displayName": "Chart padding",
      "properties": {
        "top":    { "displayName": "Top",    "type": { "numeric": true } },
        "right":  { "displayName": "Right",  "type": { "numeric": true } },
        "bottom": { "displayName": "Bottom", "type": { "numeric": true } },
        "left":   { "displayName": "Left",   "type": { "numeric": true } }
      }
    }
  },
  "supportsHighlight": false,
  "supportsKeyboardFocus": true,
  "supportsMultiVisualSelection": false,
  "supportsEmptyDataView": true,
  "supportsLandingPage": true,
  "privileges": [],
  "filterAdapters": [
    {
      "type": "advancedFilter",
      "role": "measure"
    }
  ]
}
